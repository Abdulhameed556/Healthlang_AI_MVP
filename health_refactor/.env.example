# Copy to `.env` at the repo root:  cp .env.example .env
# All variables below are read from the environment (see backend/src/core/config.py,
# admin/src/core/config.py, ai/src/core/config.py). Deployment reference: docs/deployment.md

# ── App (shared) ─────────────────────────────────────────────
APP_NAME=SupportOS AI
APP_SLUG=supportos-ai
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
LOG_LEVEL=INFO

# ── Gunicorn (Docker / Render — optional overrides) ───────────
# PORT=8000
# GUNICORN_WORKERS=2
# WEB_CONCURRENCY=2
# GUNICORN_TIMEOUT=120

# ── Database (shared — one DB, separate tables per app) ───────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/supportos
DATABASE_SQL_ECHO=false
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_RECYCLE=300
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
# Worker only — fresh connection per Dramatiq job (set automatically by make worker)
# DATABASE_USE_NULL_POOL=true

# ── Redis (shared host; apps may use different DB indices) ────
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════════════════════════════════════
# BACKEND (product dashboard — backend/src/core/config.py)
# ══════════════════════════════════════════════════════════════

# JWT — backend sessions (MUST differ from ADMIN_JWT_SECRET_KEY)
JWT_SECRET_KEY=CHANGE_ME_backend_secret_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Fernet key for API tool bearer tokens and integration secrets at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_TOOL_SECRETS_ENCRYPTION_KEY=CHANGE_ME_fernet_key

# Storage (knowledge base uploads, etc.)
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Email
EMAIL_PROVIDER=log
EMAIL_FROM=SupportOS AI <noreply@supportos.ai>
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_API_BASE=https://api.mailgun.net/v3
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Product app (invitation links, CORS)
# Local:  http://localhost:3000
# Dev:    https://supportos-dev.getindex.ai
# Prod:   https://supportos.getindex.ai
PRODUCT_APP_BASE_URL=http://localhost:3000
INVITATION_EXPIRE_HOURS=72
PASSWORD_RESET_EXPIRE_HOURS=1

# CORS — comma-separated allowed origins.
# In APP_ENV=development, omit this to allow all origins (no config needed locally).
# Required in production: CORS_ORIGINS=https://app.example.com
# CORS_ORIGINS=http://localhost:3000,http://localhost:8001

# Dev-only email toggles (default: log links, do not send)
# SEND_INVITATION_EMAIL_IN_DEV=false
# SEND_PASSWORD_RESET_EMAIL_IN_DEV=false

# Google OAuth (product login / invite acceptance)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# AI service (internal HTTP from backend)
AI_SERVICE_BASE_URL=http://localhost:8001
AI_SERVICE_INTERNAL_API_KEY=CHANGE_ME

# Admin → backend internal routes
ADMIN_INTERNAL_API_KEY=CHANGE_ME_shared_secret_openssl_rand_hex_32

# Freshchat (backend/src/core/freshchat_settings.py — see freshchat-integration.md)
API_PUBLIC_BASE_URL=
FRESHCHAT_WEBHOOK_PUBLIC_KEY=
FRESHCHAT_HANDOFF_STATUS=new
FRESHCHAT_HANDOFF_RELEASE_ACTIONS=conversation_resolution,conversation_reopen
FRESHCHAT_RESOLVE_STATUS=resolved
# FRESHCHAT_WEBHOOK_CAPTURE_TO_FILE=false
# When true, Freshchat image attachments are read with OpenAI vision before the bot replies.
ENABLE_IMAGE_ATTACHMENTS=false
# Comma-separated allowlist of inbound attachment types the bot can handle (image, file, video).
# Anything else triggers live-support handoff. Default in code: image only.
# FRESHCHAT_ALLOWED_INBOUND_ATTACHMENT_TYPES=image
# ENABLE_UNSUPPORTED_ATTACHMENT_HANDOFF=true
# Pipe-separated handoff replies (random pick). Same theme: can't review doc → support agent.
# FRESHCHAT_UNSUPPORTED_ATTACHMENT_REPLIES=I can't review that document — a human support agent is taking over from here.|I'm not able to open that file — a support agent is stepping in now.
# FRESHCHAT_UNSUPPORTED_ATTACHMENT_NO_GROUP_REPLIES=We got your file — our team will follow up.|Thanks, someone will reach out soon.

# ══════════════════════════════════════════════════════════════
# AI SERVICE (ai/src/core/config.py — worker + optional make dev-ai)
# ══════════════════════════════════════════════════════════════

AI_APP_PORT=8001
BACKEND_BASE_URL=http://localhost:8000
BACKEND_INTERNAL_API_KEY=CHANGE_ME
INTERNAL_API_KEY=CHANGE_ME

# LLM providers (worker needs at least one for the bot)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
# GEMINI_API_KEY=

DEFAULT_LLM_PROVIDER=openai
DEFAULT_CHAT_MODEL=gpt-4o
DEFAULT_VOICE_MODEL=gpt-4o-realtime-preview
DEFAULT_JUDGE_MODEL=gpt-4o
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# Vector store / KB indexing
VECTOR_STORE_BACKEND=pinecone
# Defaults to DATABASE_URL when unset
# VECTOR_STORE_URL=postgresql+asyncpg://postgres:password@localhost:5432/supportos
PINECONE_API_KEY=
PINECONE_INDEX_NAME=supportos

# Dramatiq broker (defaults to REDIS_URL / db 2 when unset)
# DRAMATIQ_BROKER_URL=redis://localhost:6379/2

# ══════════════════════════════════════════════════════════════
# ADMIN PANEL (admin/src/core/config.py)
# ══════════════════════════════════════════════════════════════

# JWT — admin sessions (MUST differ from JWT_SECRET_KEY above)
ADMIN_JWT_SECRET_KEY=CHANGE_ME_admin_secret_openssl_rand_hex_64
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

ADMIN_EMAIL_FROM=admin-panel@platform.com

# Seeded admin account (used only by make seed)
SEED_ADMIN_EMAIL=admin@platform.com
SEED_ADMIN_PASSWORD=CHANGE_ME_on_first_login

# Account lockout (admin login)
MAX_FAILED_LOGIN_ATTEMPTS=5
